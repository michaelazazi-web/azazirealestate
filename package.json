{
  "name": "azazirealestate",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:api": "cd server && node index.js",
    "dev:all": "concurrently -n \"vite,api\" -c \"cyan,yellow\" \"vite\" \"cd server && node index.js\"",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "server:install": "cd server && npm install",
    "dev:wrangler": "concurrently -n \"vite,wrangler\" -c \"cyan,yellow\" \"vite\" \"wrangler pages dev --proxy 5173\""
  },
  "dependencies": {
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-router-dom": "^7.16.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^8.2.2",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "sharp": "^0.34.5",
    "vite": "^8.0.12",
    "wrangler": "^4.95.0"
  }
}
